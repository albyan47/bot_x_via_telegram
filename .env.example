OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional alternative provider. If GEMINI_API_KEY is set, it is used when OPENAI_API_KEY is empty.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Keep false until you are confident the queue quality is good.
AUTO_PUBLISH=false

# X API read access for source collection.
X_BEARER_TOKEN=

# X API OAuth 1.0a credentials for publishing tweets.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Telegram bot for sending approved drafts to your phone.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

QUEUE_FILE=data/queue.jsonl
STATE_FILE=data/state.json
SOURCES_FILE=sources.yaml

POSTS_PER_DAY=3
INTERACTIONS_PER_DAY=3
MIN_SOURCE_ENGAGEMENT=50
